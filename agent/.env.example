# vibe-trading-A public-safe example configuration
#
# This file is intentionally minimal. It does not include cloud model keys,
# third-party service credentials, broker credentials, or private
# deployment secrets.
#
# Keep real credentials only in your private local `.env` file or in your
# deployment platform's secret manager. Never commit them to a public repo.

# Local model path by default. Requires a local Ollama service if you want LLM
# features during development. You may also configure another provider in your
# own private `.env`, but do not publish that file.
LANGCHAIN_PROVIDER=ollama
LANGCHAIN_MODEL_NAME=qwen2.5:32b
OLLAMA_BASE_URL=http://localhost:11434
LANGCHAIN_TEMPERATURE=0.0
TIMEOUT_SECONDS=120
MAX_RETRIES=2

# Public/free data-source mode. A-share research should prefer free public
# sources and local cache in the open-source version.
VIBE_TRADING_DATA_CACHE=1

# Local development server. Keep the server bound to localhost unless you have
# configured proper authentication, HTTPS, and database isolation.
CORS_ORIGINS=http://localhost:5899,http://localhost:5173
ENABLE_SESSION_RUNTIME=true
VIBE_TRADING_TRUST_DOCKER_LOOPBACK=0
VIBE_TRADING_ENABLE_SHELL_TOOLS=0

# Product safety. The open-source version is research-only by default.
VIBE_TRADING_PRODUCT_MODE=research
VIBE_TRADING_ENABLE_LIVE_TRADING=0

# Cost safety. Public deployments must not let users consume server-owned
# model or data-source credentials. Keep this at 0 unless the deployment is a
# private, trusted single-tenant environment.
VIBE_TRADING_ALLOW_SERVER_SHARED_SECRETS=0

# Example local admin. Change these in private deployment configuration.
VIBE_TRADING_ADMIN_EMAIL=admin@example.com
VIBE_TRADING_AUTH_ACCESS_CODE=change-me-access-code

# Agent/runtime tuning.
SWARM_WORKER_TIMEOUT=300
SWARM_WORKER_MAX_ITER=50
SWARM_MAX_WORKERS=4
SWARM_TIMEOUT=1800
SUBAGENT_TIMEOUT=300
SUBAGENT_MAX_ITER=25
VIBE_TRADING_TOOL_TIMEOUT_SECONDS=1800
VIBE_TRADING_SSE_TIMEOUT=90
CONTENT_FILTER_WARNING_THRESHOLD=0.05
